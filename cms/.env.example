# Postgres
DB_USER=directus
DB_PASSWORD=directus
DB_DATABASE=directus

# Directus
DIRECTUS_PORT=8055
DIRECTUS_SECRET=insecure-local-secret-change-me
DIRECTUS_PUBLIC_URL=http://localhost:8055
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=astro-note-admin
DIRECTUS_ADMIN_TOKEN=astro-note-admin-token

# beehiiv (used by Directus Flows)
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Production only
CMS_DOMAIN=cms.example.com
