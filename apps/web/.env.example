# ── Directus ────────────────────────────────────────────────────────────────
# URL of the Directus instance (local: http://localhost:8055)
DIRECTUS_URL=http://localhost:8055
# Read-only role token used by the web app (published content only, no leads read)
DIRECTUS_STATIC_TOKEN=astro-note-web-read-token
# Server-only token allowed to create/read leads (used by /api/lead + report page)
DIRECTUS_LEADS_TOKEN=astro-note-admin-token

# ── Report tokens ───────────────────────────────────────────────────────────
# HMAC secret for signed report URLs (32+ random bytes, base64/hex)
REPORT_TOKEN_SECRET=dev-only-secret-change-me-32-bytes-min!!

# ── beehiiv ─────────────────────────────────────────────────────────────────
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# ── Meta CAPI (optional; browser pixel id comes from the tenant in CMS) ────
META_CAPI_TOKEN=

# ── Multi-tenancy ───────────────────────────────────────────────────────────
# Tenant slug used in local dev / as fallback when host lookup fails
DEFAULT_TENANT=astro-note
